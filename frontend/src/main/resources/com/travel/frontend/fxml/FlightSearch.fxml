<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.travel.frontend.controller.FlightSearchController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox styleClass="page-container" spacing="20">
        <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

        <Label text="Flight Search" styleClass="page-title"/>
        <Label text="Search for available flights between airports." styleClass="page-subtitle"/>

        <!-- Airport Search Row -->
        <HBox spacing="20">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Origin Airport" styleClass="field-label"/>
                <HBox spacing="8">
                    <TextField fx:id="originQueryField" promptText="e.g. New York" HBox.hgrow="ALWAYS" onAction="#searchOriginAirports"/>
                    <Button text="Search" onAction="#searchOriginAirports" styleClass="btn-secondary"/>
                </HBox>
                <ListView fx:id="originList" prefHeight="120" styleClass="airport-list"
                          onMouseClicked="#selectOrigin"/>
            </VBox>
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Destination Airport" styleClass="field-label"/>
                <HBox spacing="8">
                    <TextField fx:id="destQueryField" promptText="e.g. London" HBox.hgrow="ALWAYS" onAction="#searchDestAirports"/>
                    <Button text="Search" onAction="#searchDestAirports" styleClass="btn-secondary"/>
                </HBox>
                <ListView fx:id="destList" prefHeight="120" styleClass="airport-list"
                          onMouseClicked="#selectDest"/>
            </VBox>
        </HBox>

        <!-- Date + Cabin -->
        <HBox spacing="24" alignment="CENTER_LEFT">
            <VBox spacing="6">
                <Label text="Flight Date" styleClass="field-label"/>
                <DatePicker fx:id="flightDatePicker"/>
            </VBox>
            <VBox spacing="6">
                <Label text="Cabin Class" styleClass="field-label"/>
                <ComboBox fx:id="cabinClassCombo" prefWidth="160"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Search Flights" onAction="#searchFlights" styleClass="btn-primary"/>
        </HBox>

        <Label fx:id="statusLabel" styleClass="status-label"/>

        <!-- Results Table -->
        <VBox styleClass="card" spacing="12">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Available Flights" styleClass="section-title"/>

            <TableView fx:id="resultsTable" prefHeight="280">
                <columns>
                    <TableColumn fx:id="colAirline" text="Airline" prefWidth="130"/>
                    <TableColumn fx:id="colRoute" text="Route" prefWidth="220"/>
                    <TableColumn fx:id="colDeparture" text="Departure" prefWidth="130"/>
                    <TableColumn fx:id="colArrival" text="Arrival" prefWidth="130"/>
                    <TableColumn fx:id="colDuration" text="Duration" prefWidth="80"/>
                    <TableColumn fx:id="colStops" text="Stops" prefWidth="80"/>
                    <TableColumn fx:id="colPrice" text="Price" prefWidth="90"/>
                </columns>
                <placeholder><Label text="No flights found. Search above."/></placeholder>
            </TableView>

            <HBox spacing="16" alignment="CENTER_LEFT">
                <Button text="Select This Flight" onAction="#selectFlight" styleClass="btn-primary"/>
                <Label fx:id="selectedFlightLabel" styleClass="selected-label"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
