<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.travel.frontend.controller.HotelController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox styleClass="page-container" spacing="20">
        <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

        <Label text="Hotel Search" styleClass="page-title"/>
        <Label text="Search for a location, then find hotels for your stay." styleClass="page-subtitle"/>

        <!-- Location Search -->
        <VBox spacing="8">
            <Label text="Location" styleClass="field-label"/>
            <HBox spacing="8">
                <TextField fx:id="locationQueryField" promptText="e.g. New York" HBox.hgrow="ALWAYS" onAction="#searchLocations"/>
                <Button text="Search" onAction="#searchLocations" styleClass="btn-secondary"/>
            </HBox>
            <ListView fx:id="locationList" prefHeight="120" styleClass="airport-list"
                      onMouseClicked="#selectLocation"/>
        </VBox>

        <!-- Dates -->
        <HBox spacing="24" alignment="CENTER_LEFT">
            <VBox spacing="6">
                <Label text="Check-in" styleClass="field-label"/>
                <DatePicker fx:id="checkInPicker"/>
            </VBox>
            <VBox spacing="6">
                <Label text="Check-out" styleClass="field-label"/>
                <DatePicker fx:id="checkOutPicker"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Search Hotels" onAction="#searchHotels" styleClass="btn-primary"/>
        </HBox>

        <Label fx:id="statusLabel" styleClass="status-label"/>

        <!-- Results Table -->
        <VBox styleClass="card" spacing="12">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Available Hotels" styleClass="section-title"/>

            <TableView fx:id="resultsTable" prefHeight="280">
                <columns>
                    <TableColumn fx:id="colName" text="Hotel" prefWidth="220"/>
                    <TableColumn fx:id="colLocation" text="Location" prefWidth="150"/>
                    <TableColumn fx:id="colRating" text="Rating" prefWidth="140"/>
                    <TableColumn fx:id="colPrice" text="Price" prefWidth="120"/>
                </columns>
                <placeholder><Label text="No hotels found. Search above."/></placeholder>
            </TableView>

            <HBox spacing="16" alignment="CENTER_LEFT">
                <Button text="Select This Hotel" onAction="#selectHotel" styleClass="btn-primary"/>
                <Label fx:id="selectedHotelLabel" styleClass="selected-label"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>